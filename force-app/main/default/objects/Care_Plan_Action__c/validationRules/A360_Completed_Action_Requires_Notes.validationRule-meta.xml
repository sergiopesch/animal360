<?xml version="1.0" encoding="UTF-8" ?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <description>Completed actions require completion notes.</description>
    <errorConditionFormula
  >AND(ISPICKVAL(Status__c, &quot;Completed&quot;), ISBLANK(Completion_Notes__c))</errorConditionFormula>
    <errorMessage
  >Enter completion notes before marking the action completed.</errorMessage>
    <fullName>A360_Completed_Action_Requires_Notes</fullName>
</ValidationRule>
