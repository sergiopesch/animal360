<?xml version="1.0" encoding="UTF-8" ?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <description
  >Ensures identifier end dates do not precede start dates.</description>
    <errorConditionFormula
  >AND(NOT(ISBLANK(End_Date__c)), NOT(ISBLANK(Start_Date__c)), End_Date__c &lt; Start_Date__c)</errorConditionFormula>
    <errorMessage>End Date must be on or after Start Date.</errorMessage>
    <fullName>A360_Identifier_End_After_Start</fullName>
</ValidationRule>
